{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",

    /* Modules */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "types": ["bun-types"],

    "paths": {
      "@hebo-ai/gateway": ["../../src/"],
      "@hebo-ai/gateway/*": ["../../src/*"]
    },

    /* Type Checking */
    "strict": true,

    /* Completeness */
    "skipLibCheck": true
  }
}
