{
  "name": "@hebo-ai/gateway",
  "version": "0.8.0",
  "description": "AI gateway as a framework. For full control over models, routing & lifecycle. OpenAI-compatible /chat/completions, /embeddings & /models.",
  "keywords": [
    "ai",
    "ai-gateway",
    "anthropic",
    "bedrock",
    "elysiajs",
    "gateway",
    "groq",
    "hono",
    "llm",
    "llm-gateway",
    "llmops",
    "nextjs",
    "openai",
    "tanstack-start",
    "vercel-ai-sdk",
    "vertex",
    "voyage"
  ],
  "homepage": "https://hebo.ai/gateway",
  "bugs": {
    "url": "https://github.com/8monkey-ai/hebo-gateway/issues"
  },
  "license": "FSL-1.1-ALv2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/8monkey-ai/hebo-gateway.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/logger/index.js",
    "./dist/providers/**/*.js",
    "./dist/models/**/*.js",
    "./src/logger/index.ts",
    "./src/providers/**/*.ts",
    "./src/models/**/*.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./endpoints/chat-completions": {
      "types": "./dist/endpoints/chat-completions/index.d.ts",
      "import": "./dist/endpoints/chat-completions/index.js"
    },
    "./endpoints/conversations": {
      "types": "./dist/endpoints/conversations/index.d.ts",
      "import": "./dist/endpoints/conversations/index.js",
      "dev-source": "./src/endpoints/conversations/index.ts"
    },
    "./endpoints/embeddings": {
      "types": "./dist/endpoints/embeddings/index.d.ts",
      "import": "./dist/endpoints/embeddings/index.js"
    },
    "./endpoints/models": {
      "types": "./dist/endpoints/models/index.d.ts",
      "import": "./dist/endpoints/models/index.js"
    },
    "./storage/memory": {
      "types": "./dist/endpoints/conversations/storage/memory.d.ts",
      "import": "./dist/endpoints/conversations/storage/memory.js",
      "dev-source": "./src/endpoints/conversations/storage/memory.ts"
    },
    "./storage/sql": {
      "types": "./dist/endpoints/conversations/storage/sql.d.ts",
      "import": "./dist/endpoints/conversations/storage/sql.js",
      "dev-source": "./src/endpoints/conversations/storage/sql.ts"
    },
    "./errors/openai": {
      "types": "./dist/errors/openai.d.ts",
      "import": "./dist/errors/openai.js"
    },
    "./middleware/common": {
      "types": "./dist/middleware/common.d.ts",
      "import": "./dist/middleware/common.js"
    },
    "./models/amazon": {
      "types": "./dist/models/amazon/index.d.ts",
      "import": "./dist/models/amazon/index.js"
    },
    "./models/anthropic": {
      "types": "./dist/models/anthropic/index.d.ts",
      "import": "./dist/models/anthropic/index.js"
    },
    "./models/cohere": {
      "types": "./dist/models/cohere/index.d.ts",
      "import": "./dist/models/cohere/index.js"
    },
    "./models/google": {
      "types": "./dist/models/google/index.d.ts",
      "import": "./dist/models/google/index.js"
    },
    "./models/openai": {
      "types": "./dist/models/openai/index.d.ts",
      "import": "./dist/models/openai/index.js"
    },
    "./models/meta": {
      "types": "./dist/models/meta/index.d.ts",
      "import": "./dist/models/meta/index.js"
    },
    "./models/voyage": {
      "types": "./dist/models/voyage/index.d.ts",
      "import": "./dist/models/voyage/index.js"
    },
    "./providers/anthropic": {
      "types": "./dist/providers/anthropic/index.d.ts",
      "import": "./dist/providers/anthropic/index.js"
    },
    "./providers/bedrock": {
      "types": "./dist/providers/bedrock/index.d.ts",
      "import": "./dist/providers/bedrock/index.js"
    },
    "./providers/cohere": {
      "types": "./dist/providers/cohere/index.d.ts",
      "import": "./dist/providers/cohere/index.js"
    },
    "./providers/groq": {
      "types": "./dist/providers/groq/index.d.ts",
      "import": "./dist/providers/groq/index.js"
    },
    "./providers/openai": {
      "types": "./dist/providers/openai/index.d.ts",
      "import": "./dist/providers/openai/index.js"
    },
    "./providers/vertex": {
      "types": "./dist/providers/vertex/index.d.ts",
      "import": "./dist/providers/vertex/index.js"
    },
    "./providers/voyage": {
      "types": "./dist/providers/voyage/index.d.ts",
      "import": "./dist/providers/voyage/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "bun --hot src/index.ts",
    "clean": "git clean -fdx -e '.env*' .",
    "format": "oxfmt .",
    "format:staged": "oxfmt --no-error-on-unmatched-pattern",
    "lint": "oxlint",
    "lint:staged": "oxlint --fix",
    "typecheck": "oxlint --type-check",
    "test": "bun test",
    "check": "bun lint && bun typecheck",
    "fix": "bun lint:staged && bun fmt:staged"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "ai": "^6.0.116",
    "lru-cache": "^11.2.6",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.77",
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/cohere": "^3.0.25",
    "@ai-sdk/google-vertex": "^4.0.80",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/openai": "^3.0.41",
    "@aws-sdk/credential-providers": "^3.1004.0",
    "@langfuse/otel": "^4.6.1",
    "@libsql/client": "^0.17.0",
    "@mjackson/node-fetch-server": "^0.7.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@tanstack/react-router": "^1.166.3",
    "@tanstack/react-start": "^1.166.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "better-sqlite3": "^12.6.2",
    "elysia": "^1.4.27",
    "hono": "^4.12.5",
    "lefthook": "^2.1.3",
    "mysql2": "^3.18.2",
    "next": "^16.1.6",
    "oxfmt": "^0.24.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "voyage-ai-provider": "^3.0.0"
  },
  "peerDependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.77",
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/cohere": "^3.0.25",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/google-vertex": "^4.0.80",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/openai": "^3.0.41",
    "@libsql/client": "^0.14.0",
    "@opentelemetry/api": "^1.9.0",
    "better-sqlite3": "^11.0.0",
    "mysql2": "^3.11.0",
    "pg": "^8.13.0",
    "postgres": "^3.4.0",
    "typescript": "^5.9.3",
    "voyage-ai-provider": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/amazon-bedrock": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/cohere": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/google-vertex": {
      "optional": true
    },
    "@ai-sdk/groq": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "voyage-ai-provider": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "postgres": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "@libsql/client": {
      "optional": true
    }
  }
}
